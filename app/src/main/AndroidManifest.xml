<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.ar" android:required="false" />
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <queries>
        <package android:name="com.google.android.gms" />
        <package android:name="com.android.vending" />
        <package android:name="com.google.android.apps.maps" />
        <package android:name="com.google.ar.core" />
        <!-- Para el intent de mapas -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <!-- Para el intent de compartir -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>

    <application
        android:name="com.infoar.app.InfoArApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:extractNativeLibs="true"
        android:theme="@style/Theme.PARCIAL2Proyecto">

        <activity
            android:name="com.infoar.app.ui.splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.infoar.app.ui.home.HomeActivity"
            android:exported="false" />

        <activity
            android:name="com.infoar.app.ui.auth.AuthActivity"
            android:exported="false" />

        <activity
            android:name="com.infoar.app.ui.detail.DetailActivity"
            android:exported="false" />

        <activity
            android:name="com.infoar.app.ui.addedit.AddEditActivity"
            android:exported="false" />

        <activity
            android:name="com.infoar.app.ui.ar.ArViewActivity"
            android:exported="false" />

        <activity
            android:name="com.utp.parcial2_proyecto.MainActivity"
            android:exported="false" />

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyAH7H-chghKA_aXGwMTj_MkI2Dx5_S1AWw" />

        <!-- Llave explícita para ARCore -->
        <meta-data
            android:name="com.google.ar.core.API_KEY"
            android:value="AIzaSyAH7H-chghKA_aXGwMTj_MkI2Dx5_S1AWw" />

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!-- ARCore Config -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

    </application>

</manifest>